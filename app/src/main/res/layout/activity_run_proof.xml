<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- 상단바 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textSize="22sp"
            android:textColor="#000000"
            android:paddingHorizontal="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="러닝 인증"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="30dp">

            <TextView
                android:id="@+id/tvMeetingName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="퇴근 후 여의도 5K 가볍게"
                android:textColor="#2F80FF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- 사진 촬영 영역 -->
            <FrameLayout
                android:id="@+id/layoutPhoto"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="@drawable/bg_dashed">

                <ImageView
                    android:id="@+id/ivPhoto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:contentDescription="러닝 사진" />

                <LinearLayout
                    android:id="@+id/layoutPhotoHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📷"
                        android:textSize="34sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="러닝 사진 촬영하기"
                        android:textColor="#2F80FF"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="눌러서 카메라를 켜세요"
                        android:textColor="#8A94A6"
                        android:textSize="12sp" />
                </LinearLayout>
            </FrameLayout>

            <!-- 다시 촬영 버튼 (사진 찍은 뒤에만 보임) -->
            <TextView
                android:id="@+id/tvRetake"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="🔄 다시 촬영"
                android:textColor="#2F80FF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:padding="8dp"
                android:visibility="gone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="기록 입력"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="#000000"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp" />

            <!-- 거리 / 시간 / 페이스 (가로 3칸) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- 거리 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:background="@drawable/bg_card"
                    android:paddingTop="10dp"
                    android:paddingBottom="6dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="거리"
                        android:textSize="12sp"
                        android:textColor="#8A94A6" />

                    <EditText
                        android:id="@+id/etDistance"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:background="@null"
                        android:hint="5.2"
                        android:textColorHint="#C3CAD6"
                        android:inputType="numberDecimal"
                        android:gravity="center"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:imeOptions="actionNext"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:autofillHints="" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="km"
                        android:textSize="11sp"
                        android:textColor="#C3CAD6" />
                </LinearLayout>

                <!-- 시간 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:background="@drawable/bg_card"
                    android:paddingTop="10dp"
                    android:paddingBottom="6dp"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="시간"
                        android:textSize="12sp"
                        android:textColor="#8A94A6" />

                    <EditText
                        android:id="@+id/etTime"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:background="@null"
                        android:hint="32:15"
                        android:textColorHint="#C3CAD6"
                        android:inputType="text"
                        android:gravity="center"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:imeOptions="actionNext"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:autofillHints="" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="분:초"
                        android:textSize="11sp"
                        android:textColor="#C3CAD6" />
                </LinearLayout>

                <!-- 페이스 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:background="@drawable/bg_card"
                    android:paddingTop="10dp"
                    android:paddingBottom="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="페이스"
                        android:textSize="12sp"
                        android:textColor="#8A94A6" />

                    <EditText
                        android:id="@+id/etPace"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:background="@null"
                        android:hint="6'12"
                        android:textColorHint="#C3CAD6"
                        android:inputType="text"
                        android:gravity="center"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:imeOptions="actionDone"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:autofillHints="" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="/km"
                        android:textSize="11sp"
                        android:textColor="#C3CAD6" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="한줄 소감 (선택)"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="#000000"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp" />

            <EditText
                android:id="@+id/etMemo"
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:background="@drawable/bg_card"
                android:gravity="top|start"
                android:padding="16dp"
                android:hint="오늘도 완주! 노을이 예뻤던 여의도 🌇"
                android:textColorHint="#C3CAD6"
                android:textSize="15sp"
                android:lineSpacingExtra="4dp"
                android:inputType="textMultiLine|textCapSentences"
                android:imeOptions="actionDone"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:scrollbars="vertical"
                android:autofillHints="" />

            <TextView
                android:id="@+id/btnComplete"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_gradient_blue"
                android:gravity="center"
                android:text="인증 완료"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="28dp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>