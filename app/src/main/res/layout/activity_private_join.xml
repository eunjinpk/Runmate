<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#99123A66">

    <TextView
        android:id="@+id/tvBack"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_margin="16dp"
        android:background="#40FFFFFF"
        android:gravity="center"
        android:text="←"
        android:textColor="#FFFFFF"
        android:textSize="20sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginHorizontal="28dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:background="@drawable/bg_card"
        android:padding="26dp">

        <TextView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_circle"
            android:backgroundTint="#EAF2FF"
            android:gravity="center"
            android:text="🔒"
            android:textSize="24sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="비공개 모임입니다"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="14dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="호스트에게 받은 초대코드를 입력하면\n모임에 입장할 수 있어요"
            android:gravity="center"
            android:textColor="#8A94A6"
            android:textSize="13sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginTop="6dp" />

        <EditText
            android:id="@+id/etCode"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_card"
            android:gravity="center"
            android:hint="초대코드 입력"
            android:inputType="text"
            android:layout_marginTop="20dp"
            android:autofillHints="" />

        <TextView
            android:id="@+id/tvError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#E04B4B"
            android:textSize="12sp"
            android:visibility="gone"
            android:layout_marginTop="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <TextView
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card"
                android:backgroundTint="#F2F4F8"
                android:gravity="center"
                android:text="취소"
                android:textColor="#5A6272"
                android:textStyle="bold"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/btnJoin"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/bg_gradient_blue"
                android:gravity="center"
                android:text="입장하기"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>