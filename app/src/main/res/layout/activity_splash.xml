<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/splashRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:clickable="true"
    android:focusable="true"
    android:background="@color/run_blue">

    <TextView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:background="@drawable/bg_circle"
        android:backgroundTint="@color/surface_white"
        android:gravity="center"
        android:text="🏃"
        android:textSize="48sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="런메이트"
        android:textColor="@color/surface_white"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="한강공원을 함께 달리는 러닝 크루"
        android:textColor="@color/surface_white"
        android:textSize="14sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="화면을 탭하면 바로 시작해요"
        android:textColor="@color/run_sky"
        android:textSize="12sp" />

</LinearLayout>