<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 지도 영역: 지도/장소 담당 화면 완성되면 실제 지도로 교체 -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="@color/run_sky">

                <TextView
                    android:id="@+id/btnBack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|start"
                    android:layout_margin="16dp"
                    android:background="@drawable/bg_circle"
                    android:backgroundTint="@color/surface_white"
                    android:gravity="center"
                    android:padding="10dp"
                    android:text="←"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp" />

                <!-- 내가 만든 모임일 때만 보임 (호스트 전용 삭제) -->
                <TextView
                    android:id="@+id/btnDeleteMeeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="16dp"
                    android:background="@drawable/bg_circle"
                    android:backgroundTint="@color/surface_white"
                    android:gravity="center"
                    android:padding="10dp"
                    android:text="🗑"
                    android:textSize="16sp"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="📍"
                    android:textSize="36sp" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- 뱃지: 공개여부 + 마감임박 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvUrgentBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_rounded_badge"
                        android:backgroundTint="@color/badge_urgent_bg"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="3dp"
                        android:text="🔥 마감임박"
                        android:textColor="@color/badge_urgent_text"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tvPublicBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_rounded_badge"
                        android:backgroundTint="@color/chip_public_bg"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="3dp"
                        android:text="공개"
                        android:textColor="@color/chip_public_text"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- 제목 -->
                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="퇴근 후 여의도 5K 가볍게"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- 정보 카드 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_search_bar"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvLocation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📍 여의도한강공원"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvDateTime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="📅 오늘 오후 6:30"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvFineAndPace"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="⏰ 페이스 6~7'/km"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- 설명 -->
                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="가볍게 5km 뛰어요"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <!-- 참여자 헤더 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvParticipantCount"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="참여자 0/0"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSpotsLeft"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="자리 있음"
                        android:textColor="@color/badge_urgent_text"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- 참여자 목록: 코드로 동적 생성 -->
                <LinearLayout
                    android:id="@+id/layoutParticipants"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- 하단 고정 버튼 영역 -->
    <LinearLayout
        android:id="@+id/bottomButtonBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_white"
        android:elevation="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- 참여 전에는 숨겨짐. 참여 확정되면 "취소하기"로 나타남 -->
        <TextView
            android:id="@+id/btnSecondary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_chip_unselected"
            android:gravity="center"
            android:padding="14dp"
            android:text="취소하기"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/btnJoin"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_chip_selected"
            android:gravity="center"
            android:padding="14dp"
            android:text="참여하기"
            android:textColor="@color/surface_white"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>